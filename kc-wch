#!/bin/bash
# Watch and notifies folders and file changes
# Summary: Emits add, upd, and del events for files and directories.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

declare -A known_paths=()

# Prints application usage help.
# @return 0 on success.
kc_wch_help() {
    echo "Options:"
    echo "  <path>   Path to folder or file"
    echo "  -h       Show help"
    echo
    echo "Examples:"
    echo "  kc-wch ."
    echo "  kc-wch ./file.txt"
    echo
    echo "Dependencies:"
    echo "  inotify-tools"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_wch_fail() {
    echo "Error: $1" >&2
    kc_wch_help >&2
    return 1
}

# Watches the given path and dispatches to the appropriate watcher.
# @param $1 Path to a directory or file
# @return 0 when a watcher starts, 1 when the path is invalid
main() {

    if [[ "$1" = "-h" || "$1" = "--help" ]]; then
        kc_wch_help
        return 0
    fi

    if ! command -v inotifywait >/dev/null 2>&1; then
        kc_wch_fail "inotifywait not found" || exit 1
    fi

    if [ -d "$1" ]; then
        watch_d "$1"
        return
    fi

    if [ -f "$1" ]; then
        watch_f "$1"
        return
    fi

    kc_wch_fail "Invalid path."
    exit 1
}

# Watches a directory recursively and prints add, upd, or del events.
# @param $1 Directory path
# @return Does not return while watching
watch_d() {
    local d="$1"
    local path

    known_paths["$d"]=1

    while IFS= read -r path; do
        known_paths["$path"]=1
    done < <(find "$d" -mindepth 1 2>/dev/null)

    inotifywait -q -m -r -e create -e close_write -e delete -e moved_to \
    -e moved_from --format '%e:%w%f' "$d" | while IFS=: read -r ev f; do
        print_event "$ev" "$f"
    done
}

# Watches a single file and prints add, upd, or del events for that file.
# @param $1 File path
# @return Does not return while watching
watch_f() {
    local file="$1"
    local dir
    local base

    dir="$(dirname "$file")"
    base="$(basename "$file")"

    known_paths["$file"]=1

    inotifywait -q -m -e create -e close_write -e delete -e moved_to \
    -e moved_from --format '%e:%w%f' "$dir" | while IFS=: read -r ev f; do
        [ "$(basename "$f")" = "$base" ] || continue

        print_event "$ev" "$f"
    done
}

# Prints an add, upd, or del event for the given inotify event and path.
# @param $1 Inotify event name
# @param $2 File or directory path
# @return 0 when the event is recognized
print_event() {
    local ev="$1"
    local f="$2"
    local out

    case "$ev" in
        *CREATE*|*MOVED_TO*)
            if [ -n "${known_paths[$f]+x}" ]; then
                out="upd:$f"
            else
                out="add:$f"
            fi
            known_paths["$f"]=1
            ;;
        *CLOSE_WRITE*)
            known_paths["$f"]=1
            out="upd:$f"
            ;;
        *DELETE*|*MOVED_FROM*)
            unset 'known_paths[$f]'
            out="del:$f"
            ;;
    esac

    [ -n "$out" ] || return
    echo "$out"
}

main "$@"
