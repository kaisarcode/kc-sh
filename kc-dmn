#!/bin/bash

# kc-dmn: A simple Unix socket manager for daemonized commands.
# Summary: Manages local daemon sockets and their lifecycle in XDG_RUNTIME_DIR.

# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: GNU GPL v3.0

# Options:
#   set <key> <command> Create Unix socket with daemonized command.
#   get <key>           Print socket path if it exists
#   del <key>           Remove socket and kill daemon if it exists
#   exe <key>           Execute socket
#   sts <key>           Show daemon status
#   lst                 List registered daemons
#   -h                  Show help

# Examples:
#   kc-dmn set myservice /bin/cat
#   kc-dmn get myservice
#   kc-dmn lst
#   kc-dmn sts myservice
#   echo "Hello, World!" | kc-dmn exe myservice
#   kc-dmn del myservice

# Dependencies:
#   socat

# Prints application usage help.
# @return 0 on success.
kc_dmn_help() {
    echo "Options:"
    echo "  set <key> <command> Create Unix socket with daemonized command."
    echo "  get <key>           Print socket path if it exists"
    echo "  del <key>           Remove socket and kill daemon if it exists"
    echo "  exe <key>           Execute socket"
    echo "  sts <key>           Show daemon status"
    echo "  lst                 List registered daemons"
    echo "  -h                  Show help"
    echo
    echo "Examples:"
    echo "  kc-dmn set myservice /bin/cat"
    echo "  kc-dmn get myservice"
    echo "  kc-dmn lst"
    echo "  kc-dmn sts myservice"
    echo "  echo \"Hello, World!\" | kc-dmn exe myservice"
    echo "  kc-dmn del myservice"
    echo
    echo "Dependencies:"
    echo "  socat"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_dmn_fail() {
    echo "Error: $1" >&2
    kc_dmn_help >&2
    return 1
}

# Resolve daemon runtime directory.
# Prefers XDG_RUNTIME_DIR, then /run/user/<uid>, then /tmp.
# @return 0 on success.
kc_dmn_dir() {
    local uid
    local dir

    if [ -n "$XDG_RUNTIME_DIR" ] && [ -d "$XDG_RUNTIME_DIR" ] && [ -w "$XDG_RUNTIME_DIR" ]; then
        echo "$XDG_RUNTIME_DIR/kc-dmn"
        return 0
    fi

    uid="$(id -u)"
    dir="/run/user/$uid"
    if [ -d "$dir" ] && [ -w "$dir" ]; then
        echo "$dir/kc-dmn"
        return 0
    fi

    echo "/tmp/kc-dmn-$uid"
    return 0
}

# Main entry point
# @return 0 on success, 1 on failure
main() {
    local key
    local path
    local sock
    local cmd

    if [[ "$1" = "-h" || "$1" = "--help" ]]; then
        kc_dmn_help
        return 0
    fi

    if ! command -v socat >/dev/null 2>&1; then
        kc_dmn_fail "socat not found" || exit 1
    fi

    key="$2"
    path="$(kc_dmn_dir)"
    sock="$path/$key"
    cmd="${*:3}"
    mkdir -p "$path" || return 1

    if [[
        "$1" = "set" ||
        "$1" = "add" ||
        "$1" = "create"
    ]]; then
        [ -n "$key" ] || kc_dmn_fail "Missing key for set." || return 1
        set_socket
        return $?
    fi

    if [[
        "$1" = "get" ||
        "$1" = "read"
    ]]; then
        [ -n "$key" ] || kc_dmn_fail "Missing key for get." || return 1
        get_socket
        return $?
    fi

    if [[
        "$1" = "sts" ||
        "$1" = "status"
    ]]; then
        [ -n "$key" ] || kc_dmn_fail "Missing key for sts." || return 1
        sts_socket
        return $?
    fi

    if [[
        "$1" = "lst"  ||
        "$1" = "list" ||
        "$1" = "ls"
    ]]; then
        lst_socket
        return $?
    fi

    if [[
        "$1" = "exe" ||
        "$1" = "run" ||
        "$1" = "exec"
    ]]; then
        [ -n "$key" ] || kc_dmn_fail "Missing key for exe." || return 1
        run_socket
        return $?
    fi

    if [[
        "$1" = "del" ||
        "$1" = "delete" ||
        "$1" = "remove" ||
        "$1" = "rm"
    ]]; then
        [ -n "$key" ] || kc_dmn_fail "Missing key for del." || return 1
        del_socket
        return $?
    fi

    kc_dmn_fail "Unknown command."
}

# Create socket with daemonized command
# @return 0 on success, 1 on failure
set_socket() {
    [ -z "$cmd" ] && return 1
    [ -S "$sock" ] && return 1
    nohup socat "UNIX-LISTEN:$sock,fork" "EXEC:$cmd" >/dev/null 2>&1 &
    echo $! > "$sock.pid"
    return 0
}

# Obtain socket
# @return 0 on success, 1 on failure
get_socket() {
    [ ! -S "$sock" ] && return 1
    [ ! -f "$sock.pid" ] && return 1
    echo "$sock"
    return 0
}

# Show daemon status
# @return 0 when running, 1 otherwise
sts_socket() {
    local pid
    [ -S "$sock" ] || return 1
    [ -f "$sock.pid" ] || return 1
    pid="$(cat "$sock.pid")"
    kill -0 "$pid" 2>/dev/null
}

# List registered daemons
# @return 0 on success, 1 on failure
lst_socket() {
    local file
    [ ! -d "$path" ] && return 1
    for file in "$path"/*; do
        [ -e "$file" ] || return 0
        [ -f "$file" ] && [[ "$file" = *.pid ]] && continue
        basename "$file"
    done
    return 0
}

# Execute socket
# @return 0 on success, 1 on failure
run_socket() {
    [ ! -S "$sock" ] && return 1
    exec socat - "UNIX-CONNECT:$sock"
}

# Remove socket
# @return 0 on success, 1 on failure
del_socket() {
    [ ! -S "$sock" ] && return 1
    if [ -f "$sock.pid" ]; then
        kill "$(cat "$sock.pid")" 2>/dev/null
        rm -f "$sock.pid"
    fi
    rm -f "$sock"
    return 0
}

main "$@"
