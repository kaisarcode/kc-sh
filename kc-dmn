#!/bin/bash

# kc-dmn: A simple Unix socket manager for daemonized commands.
# Summary: Registers read commands and writes values through local daemon sockets in XDG_RUNTIME_DIR.

# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

# Options:
#   get <key> <command> Register daemonized command for key
#   set <key> <value>   Write value to registered daemon key
#   fl <key>            Print daemon socket file path
#   del <key>           Remove daemon key and kill registered process if it exists
#   ls                  List registered daemon keys
#   <key>               Write standard input to registered daemon key
#   -h                  Show help

# Examples:
#   kc-dmn get myservice /bin/cat
#   kc-dmn set myservice hello
#   kc-dmn fl myservice
#   echo "Hello, World!" | kc-dmn myservice
#   kc-dmn del myservice
#   kc-dmn ls

# Dependencies:
#   socat

# Prints application usage help.
# @return 0 on success.
kc_dmn_help() {
    echo "Options:"
    echo "  get <key> <command> Register daemonized command for key"
    echo "  set <key> <value>   Write value to registered daemon key"
    echo "  fl <key>            Print daemon socket file path"
    echo "  del <key>           Remove daemon key and kill registered process if it exists"
    echo "  ls                  List registered daemon keys"
    echo "  <key>               Write standard input to registered daemon key"
    echo "  -h                  Show help"
    echo
    echo "Examples:"
    echo "  kc-dmn get myservice /bin/cat"
    echo "  kc-dmn set myservice hello"
    echo "  kc-dmn fl myservice"
    echo "  echo \"Hello, World!\" | kc-dmn myservice"
    echo "  kc-dmn del myservice"
    echo "  kc-dmn ls"
    echo
    echo "Dependencies:"
    echo "  socat"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_dmn_fail() {
    echo "Error: $1" >&2
    kc_dmn_help >&2
    return 1
}

# Resolve daemon runtime directory.
# Prefers XDG_RUNTIME_DIR, then /run/user/<uid>, then /tmp.
# @return 0 on success.
kc_dmn_dir() {
    local uid
    local dir

    if [ -n "$XDG_RUNTIME_DIR" ] && [ -d "$XDG_RUNTIME_DIR" ] && [ -w "$XDG_RUNTIME_DIR" ]; then
        echo "$XDG_RUNTIME_DIR/kc-dmn"
        return 0
    fi

    uid="$(id -u)"
    dir="/run/user/$uid"
    if [ -d "$dir" ] && [ -w "$dir" ]; then
        echo "$dir/kc-dmn"
        return 0
    fi

    echo "/tmp/kc-dmn-$uid"
    return 0
}

# Main entry point
# @return 0 on success, 1 on failure
main() {
    local key

    if [[ "$1" = "-h" || "$1" = "--help" ]]; then
        kc_dmn_help
        return 0
    fi

    if ! command -v socat >/dev/null 2>&1; then
        kc_dmn_fail "socat not found" || return 1
    fi

    path="$(kc_dmn_dir)"
    mkdir -p "$path" || return 1

    if [[ "$1" = "get" ]]; then
        key="$2"
        cmd="${*:3}"
        sock="$path/$key"
        [ -n "$key" ] || kc_dmn_fail "Missing key for get." || return 1
        [ -n "$cmd" ] || kc_dmn_fail "Missing command for get." || return 1
        get_socket
        return $?
    fi

    if [[ "$1" = "set" ]]; then
        key="$2"
        value="${*:3}"
        sock="$path/$key"
        [ -n "$key" ] || kc_dmn_fail "Missing key for set." || return 1
        [ -n "${3+x}" ] || kc_dmn_fail "Missing value for set." || return 1
        set_socket
        return $?
    fi

    if [[ "$1" = "fl" ]]; then
        key="$2"
        sock="$path/$key"
        [ -n "$key" ] || kc_dmn_fail "Missing key for fl." || return 1
        echo "$sock"
        return 0
    fi

    if [[ "$1" = "del" ]]; then
        key="$2"
        sock="$path/$key"
        [ -n "$key" ] || kc_dmn_fail "Missing key for del." || return 1
        del_socket
        return $?
    fi

    if [[ "$1" = "ls" ]]; then
        ls_socket
        return $?
    fi

    key="$1"
    sock="$path/$key"
    [ -n "$key" ] || kc_dmn_fail "Missing key." || return 1
    io_socket
}

# Register daemonized command for key
# Replaces existing daemon if it already exists.
# @return 0 on success, 1 on failure
get_socket() {
    del_socket >/dev/null 2>&1
    nohup socat "UNIX-LISTEN:$sock,fork" "EXEC:$cmd" >/dev/null 2>&1 &
    echo "$!" > "$sock.pid"
    return 0
}

# Write value to daemon socket
# @return 0 on success, 1 on failure
set_socket() {
    [ -S "$sock" ] || return 1
    printf '%s\n' "$value" | socat - "UNIX-CONNECT:$sock"
}

# List registered daemon keys
# @return 0 on success, 1 on failure
ls_socket() {
    local file

    [ -d "$path" ] || return 1

    for file in "$path"/*; do
        [ -e "$file" ] || return 0
        [ -f "$file" ] && [[ "$file" = *.pid ]] && continue
        basename "$file"
    done
    return 0
}

# Write standard input to daemon socket
# @return 0 on success, 1 on failure
io_socket() {
    [ -S "$sock" ] || return 1
    exec socat - "UNIX-CONNECT:$sock"
}

# Remove daemon socket
# @return 0 on success, 1 on failure
del_socket() {
    if [ -f "$sock.pid" ]; then
        kill "$(cat "$sock.pid")" 2>/dev/null
        rm -f "$sock.pid"
    fi
    rm -f "$sock"
    return 0
}

main "$@"
