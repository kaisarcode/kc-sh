#!/bin/bash
# kc-fifo: A simple named pipe manager.
# Summary: Writes and reads local FIFO pipes in XDG_RUNTIME_DIR.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

# Prints application usage help.
# @return 0 on success.
kc_fifo_help() {
    echo "Usage: kc-fifo [options] <action> [args...]"
    echo
    echo "Options:"
    echo "  set <key> <value>    Write value to FIFO key"
    echo "  get <key>            Read value from FIFO key"
    echo "  fl <key>             Print FIFO file path"
    echo "  del <key>            Remove FIFO key if it exists"
    echo "  ls                   List registered FIFO keys"
    echo "  <key>                Write standard input to FIFO key"
    echo "  -h, --help           Show help"
    echo
    echo "Examples:"
    echo "  kc-fifo set mypipe hello"
    echo "  kc-fifo get mypipe"
    echo "  kc-fifo fl mypipe"
    echo "  echo \"Hello, World!\" | kc-fifo mypipe"
    echo "  kc-fifo del mypipe"
    echo "  kc-fifo ls"
    echo
    echo "Dependencies:"
    echo "  mkfifo"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_fifo_fail() {
    echo "Error: $1" >&2
    kc_fifo_help >&2
    return 1
}

# Resolve FIFO runtime directory.
# Prefers XDG_RUNTIME_DIR, then /run/user/<uid>, then /tmp.
# @return 0 on success.
kc_fifo_dir() {
    local uid
    local dir

    if [ -n "$XDG_RUNTIME_DIR" ] && [ -d "$XDG_RUNTIME_DIR" ] && [ -w "$XDG_RUNTIME_DIR" ]; then
        echo "$XDG_RUNTIME_DIR/kc-fifo"
        return 0
    fi

    uid="$(id -u)"
    dir="/run/user/$uid"
    if [ -d "$dir" ] && [ -w "$dir" ]; then
        echo "$dir/kc-fifo"
        return 0
    fi

    echo "/tmp/kc-fifo-$uid"
    return 0
}

# Main entry point
# @return 0 on success, 1 on failure
main() {
    local key

    if [[ "$1" = "-h" || "$1" = "--help" ]]; then
        kc_fifo_help
        return 0
    fi

    if ! command -v mkfifo >/dev/null 2>&1; then
        kc_fifo_fail "mkfifo not found" || return 1
    fi

    path="$(kc_fifo_dir)"
    mkdir -p "$path" || return 1

    if [[ "$1" = "set" ]]; then
        key="$2"
        value="${*:3}"
        fifo="$path/$key"
        [ -n "$key" ] || kc_fifo_fail "Missing key for set." || return 1
        [ -n "${3+x}" ] || kc_fifo_fail "Missing value for set." || return 1
        set_fifo
        return $?
    fi

    if [[ "$1" = "get" ]]; then
        key="$2"
        fifo="$path/$key"
        [ -n "$key" ] || kc_fifo_fail "Missing key for get." || return 1
        get_fifo
        return $?
    fi

    if [[ "$1" = "fl" ]]; then
        key="$2"
        fifo="$path/$key"
        [ -n "$key" ] || kc_fifo_fail "Missing key for fl." || return 1
        echo "$fifo"
        return 0
    fi

    if [[ "$1" = "del" ]]; then
        key="$2"
        fifo="$path/$key"
        [ -n "$key" ] || kc_fifo_fail "Missing key for del." || return 1
        del_fifo
        return $?
    fi

    if [[ "$1" = "ls" ]]; then
        ls_fifo
        return $?
    fi

    key="$1"
    fifo="$path/$key"
    [ -n "$key" ] || kc_fifo_fail "Missing key." || return 1
    io_fifo
}

# Ensure FIFO key exists
# @return 0 on success, 1 on failure
ensure_fifo() {
    [ -p "$fifo" ] && return 0
    [ -e "$fifo" ] && return 1
    mkfifo "$fifo" || return 1
    return 0
}

# Write value to FIFO key
# @return 0 on success, 1 on failure
set_fifo() {
    ensure_fifo || return 1
    printf '%s\n' "$value" > "$fifo"
}

# Read value from FIFO key
# @return 0 on success, 1 on failure
get_fifo() {
    ensure_fifo || return 1
    cat < "$fifo"
}

# List registered FIFO keys
# @return 0 on success, 1 on failure
ls_fifo() {
    local file

    [ -d "$path" ] || return 1

    for file in "$path"/*; do
        [ -e "$file" ] || return 0
        [ -p "$file" ] || continue
        basename "$file"
    done
    return 0
}

# Write standard input to FIFO key
# @return 0 on success, 1 on failure
io_fifo() {
    ensure_fifo || return 1
    cat > "$fifo"
}

# Remove FIFO key
# @return 0 on success, 1 on failure
del_fifo() {
    rm -f "$fifo"
    return 0
}

main "$@"
