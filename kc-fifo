#!/bin/bash

# kc-fifo: A simple named pipe manager.
# Summary: Manages local FIFO pipes and their lifecycle in XDG_RUNTIME_DIR.

# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: GNU GPL v3.0

# Options:
#   set <key>           Create FIFO pipe
#   get <key>           Print FIFO path if it exists
#   del <key>           Remove FIFO pipe if it exists
#   sts <key>           Show FIFO status
#   lst                 List registered FIFOs
#   <key>               Write standard input to FIFO or read FIFO to standard output
#   -h                  Show help

# Examples:
#   kc-fifo set mypipe
#   kc-fifo get mypipe
#   kc-fifo lst
#   kc-fifo sts mypipe
#   echo "Hello, World!" | kc-fifo mypipe
#   kc-fifo mypipe
#   kc-fifo del mypipe

# Dependencies:
#   mkfifo

# Prints application usage help.
# @return 0 on success.
kc_fifo_help() {
    echo "Options:"
    echo "  set <key>           Create FIFO pipe"
    echo "  get <key>           Print FIFO path if it exists"
    echo "  del <key>           Remove FIFO pipe if it exists"
    echo "  sts <key>           Show FIFO status"
    echo "  lst                 List registered FIFOs"
    echo "  <key>               Write standard input to FIFO or read FIFO to standard output"
    echo "  -h                  Show help"
    echo
    echo "Examples:"
    echo "  kc-fifo set mypipe"
    echo "  kc-fifo get mypipe"
    echo "  kc-fifo lst"
    echo "  kc-fifo sts mypipe"
    echo "  echo \"Hello, World!\" | kc-fifo mypipe"
    echo "  kc-fifo mypipe"
    echo "  kc-fifo del mypipe"
    echo
    echo "Dependencies:"
    echo "  mkfifo"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_fifo_fail() {
    echo "Error: $1" >&2
    kc_fifo_help >&2
    return 1
}

# Resolve FIFO runtime directory.
# Prefers XDG_RUNTIME_DIR, then /run/user/<uid>, then /tmp.
# @return 0 on success.
kc_fifo_dir() {
    local uid
    local dir

    if [ -n "$XDG_RUNTIME_DIR" ] && [ -d "$XDG_RUNTIME_DIR" ] && [ -w "$XDG_RUNTIME_DIR" ]; then
        echo "$XDG_RUNTIME_DIR/kc-fifo"
        return 0
    fi

    uid="$(id -u)"
    dir="/run/user/$uid"
    if [ -d "$dir" ] && [ -w "$dir" ]; then
        echo "$dir/kc-fifo"
        return 0
    fi

    echo "/tmp/kc-fifo-$uid"
    return 0
}

# Main entry point
# @return 0 on success, 1 on failure
main() {
    local key
    local path
    local fifo

    if [[ "$1" = "-h" || "$1" = "--help" ]]; then
        kc_fifo_help
        return 0
    fi

    if ! command -v mkfifo >/dev/null 2>&1; then
        kc_fifo_fail "mkfifo not found" || exit 1
    fi

    if [[
        "$1" = "set" ||
        "$1" = "add" ||
        "$1" = "create"
    ]]; then
        key="$2"
        [ -n "$key" ] || kc_fifo_fail "Missing key for set." || return 1
        path="$(kc_fifo_dir)"
        fifo="$path/$key"
        mkdir -p "$path" || return 1
        set_fifo
        return $?
    fi

    if [[
        "$1" = "get" ||
        "$1" = "read"
    ]]; then
        key="$2"
        [ -n "$key" ] || kc_fifo_fail "Missing key for get." || return 1
        path="$(kc_fifo_dir)"
        fifo="$path/$key"
        get_fifo
        return $?
    fi

    if [[
        "$1" = "sts" ||
        "$1" = "status"
    ]]; then
        key="$2"
        [ -n "$key" ] || kc_fifo_fail "Missing key for sts." || return 1
        path="$(kc_fifo_dir)"
        fifo="$path/$key"
        sts_fifo
        return $?
    fi

    if [[
        "$1" = "lst"  ||
        "$1" = "list" ||
        "$1" = "ls"
    ]]; then
        path="$(kc_fifo_dir)"
        lst_fifo
        return $?
    fi

    if [[
        "$1" = "del" ||
        "$1" = "delete" ||
        "$1" = "remove" ||
        "$1" = "rm"
    ]]; then
        key="$2"
        [ -n "$key" ] || kc_fifo_fail "Missing key for del." || return 1
        path="$(kc_fifo_dir)"
        fifo="$path/$key"
        del_fifo
        return $?
    fi

    key="$1"
    [ -n "$key" ] || kc_fifo_fail "Missing key." || return 1
    path="$(kc_fifo_dir)"
    fifo="$path/$key"
    io_fifo
}

# Create FIFO pipe
# @return 0 on success, 1 on failure
set_fifo() {
    [ -e "$fifo" ] && return 1
    mkfifo "$fifo" || return 1
    return 0
}

# Obtain FIFO pipe
# @return 0 on success, 1 on failure
get_fifo() {
    [ ! -p "$fifo" ] && return 1
    echo "$fifo"
    return 0
}

# Show FIFO status
# @return 0 when available, 1 otherwise
sts_fifo() {
    [ -p "$fifo" ]
}

# List registered FIFOs
# @return 0 on success, 1 on failure
lst_fifo() {
    local file
    [ ! -d "$path" ] && return 1
    for file in "$path"/*; do
        [ -e "$file" ] || return 0
        [ -p "$file" ] || continue
        basename "$file"
    done
    return 0
}

# Use FIFO pipe for input or output.
# Writes standard input to FIFO when input is piped.
# Reads FIFO to standard output when input is interactive.
# @return 0 on success, 1 on failure
io_fifo() {
    [ ! -p "$fifo" ] && return 1
    if [ -t 0 ]; then
        cat < "$fifo"
        return $?
    fi
    cat > "$fifo"
    return $?
}

# Remove FIFO pipe
# @return 0 on success, 1 on failure
del_fifo() {
    [ ! -p "$fifo" ] && return 1
    rm -f "$fifo"
    return 0
}

main "$@"
