#!/bin/bash

# KC tool dispatcher.
# Summary: Runs kc-sh tools from the current script directory.

# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

# Options:
#   <tool> [args...]    Run kc-<tool> from the real script directory
#   -h                  Show help

# Examples:
#   kc-sh shm set mykey hello
#   kc-sh shm get mykey
#   kc-sh shm ls

# Prints application usage help.
# @return 0 on success.
kc_sh_help() {
    echo "Options:"
    echo "  <tool> [args...]    Run kc-<tool> from the real script directory"
    echo "  -h                  Show help"
    echo
    echo "Examples:"
    echo "  kc-sh shm set mykey hello"
    echo "  kc-sh shm get mykey"
    echo "  kc-sh shm ls"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_sh_fail() {
    echo "Error: $1" >&2
    kc_sh_help >&2
    return 1
}

# Dispatches one kc-sh command from the current script directory.
# @return 0 on success, 1 on failure.
main() {
    local self
    local root
    local cmd

    if [[ "$1" = "-h" || "$1" = "--help" || -z "$1" ]]; then
        kc_sh_help
        [ -n "$1" ]
        return $?
    fi

    self="$(readlink -f "$0")"
    root="$(dirname "$self")"
    cmd="$1"
    shift

    [ -x "$root/kc-$cmd" ] || kc_sh_fail "Unknown tool: $cmd" || return 1
    "$root/kc-$cmd" "$@"
}

main "$@"
