#!/bin/bash

# KC tool dispatcher.
# Summary: Runs kc-sh tools from the current script directory.

# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: GNU GPL v3.0

# Options:
#   -i                  Install tool from GitHub if missing locally
#   <tool> [args...]    Run kc-<tool> from the real script directory
#   -h                  Show help

# Examples:
#   kc-run shm set mykey hello
#   kc-run shm get mykey
#   kc-run shm ls
#   kc-run -i shm

# Prints application usage help.
# @return 0 on success.
kc_run_help() {
    echo "Options:"
    echo "  -i                  Install tool from GitHub if missing locally"
    echo "  <tool> [args...]    Run kc-<tool> from the real script directory"
    echo "  -h                  Show help"
    echo
    echo "Examples:"
    echo "  kc-run shm set mykey hello"
    echo "  kc-run shm get mykey"
    echo "  kc-run dmn ls"
    echo "  kc-run -i shm"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_run_fail() {
    echo "Error: $1" >&2
    kc_run_help >&2
    return 1
}

# Dispatches one kc-sh command from the current script directory.
# @return 0 on success, 1 on failure.
main() {
    local self
    local root
    local cmd
    local install=0

    if [[ "$1" = "-i" ]]; then
        install=1
        shift
    fi

    if [[ "$1" = "-h" || "$1" = "--help" || -z "$1" ]]; then
        kc_run_help
        [ -n "$1" ]
        return $?
    fi

    self="$(readlink -f "$0")"
    root="$(dirname "$self")"
    cmd="$1"
    shift

    if [ ! -x "$root/kc-$cmd" ]; then
        if [ "$install" -eq 1 ]; then
            if ! curl -sSfL "https://raw.githubusercontent.com/kaisarcode/kc-sh/refs/heads/master/kc-$cmd" -o "$root/kc-$cmd"; then
                rm -f "$root/kc-$cmd"
                kc_run_fail "Unknown tool: $cmd" || return 1
            fi
            chmod +x "$root/kc-$cmd"
        else
            kc_run_fail "Unknown tool: $cmd" || return 1
        fi
    fi
    "$root/kc-$cmd" "$@"
}

main "$@"
