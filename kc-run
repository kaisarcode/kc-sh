#!/bin/bash

# KC tool dispatcher.
# Summary: Runs kc-sh tools from the current script directory.

# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: GNU GPL v3.0

# Options:
#   -i                  Install kc-run to /usr/local/bin
#   -u                  Uninstall kc-run from /usr/local/bin
#   <tool> [args...]    Run kc-<tool> from the real script directory
#   -h                  Show help

# Examples:
#   kc-run shm set mykey hello
#   kc-run shm get mykey
#   kc-run shm ls
#   kc-run -i
#   kc-run -u

# Prints application usage help.
# @return 0 on success.
kc_run_help() {
    echo "Options:"
    echo "  -i                  Install kc-run to /usr/local/bin"
    echo "  -u                  Uninstall kc-run from /usr/local/bin"
    echo "  <tool> [args...]    Run kc-<tool> from the real script directory"
    echo "  -h                  Show help"
    echo
    echo "Examples:"
    echo "  kc-run shm set mykey hello"
    echo "  kc-run shm get mykey"
    echo "  kc-run shm ls"
    echo "  kc-run -i"
    echo "  kc-run -u"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_run_fail() {
    echo "Error: $1" >&2
    kc_run_help >&2
    return 1
}

# Dispatches one kc-sh command from the current script directory.
# @return 0 on success, 1 on failure.
main() {
    local self
    local root
    local cmd

    if [[ "$1" = "-h" || "$1" = "--help" || -z "$1" ]]; then
        kc_run_help
        [ -n "$1" ]
        return $?
    fi

    self="$(readlink -f "$0")"

    if [[ "$1" = "-i" ]]; then
        if sudo ln -sf "$self" /usr/local/bin/kc-run; then
            echo "Installed kc-run to /usr/local/bin/kc-run"
            return 0
        else
            echo "Failed to install kc-run" >&2
            return 1
        fi
    elif [[ "$1" = "-u" ]]; then
        if sudo rm -f /usr/local/bin/kc-run; then
            echo "Uninstalled kc-run from /usr/local/bin/kc-run"
            return 0
        else
            echo "Failed to uninstall kc-run" >&2
            return 1
        fi
    fi

    root="$(dirname "$self")"
    cmd="$1"
    shift

    [ -x "$root/kc-$cmd" ] || kc_run_fail "Unknown tool: $cmd" || return 1
    "$root/kc-$cmd" "$@"
}

main "$@"
