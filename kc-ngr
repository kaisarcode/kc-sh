#!/bin/bash
# kc-ngr - N-Gram Generator
# Summary: Shell implementation of descending sliding-window n-grams.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

# Prints application usage help.
# @return 0 on success.
kc_ngr_help() {
    echo "Usage: kc-ngr [options]"
    echo
    echo "Options:"
    echo "  -max <n>       Maximum tokens per block (default 10)"
    echo "  -min <n>       Minimum tokens per block (default 1)"
    echo "  -sep <s>       Custom separator characters (default spaces/newlines)"
    echo "  -cmd <cmd>     Execute command for each chunk; any stdout closes that span"
    echo "  -h, --help     Show help"
    echo
    echo "Examples:"
    echo "  echo 'one two three' | kc-ngr"
    echo "  echo 'one two three' | kc-ngr -max 2 -min 1"
    echo "  echo 'one two three' | kc-ngr -cmd 'grep -qx \"one two\" && echo cut'"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_ngr_fail() {
    echo "Error: $1" >&2
    kc_ngr_help >&2
    return 1
}

# Verifies that the given text is one unsigned integer.
# @param $1 Raw integer text
# @return 0 on success, 1 on failure.
kc_ngr_is_int() {
    case "$1" in
        ''|*[!0-9]*)
        return 1 ;;
    esac
    return 0
}

# Reads all content from standard input.
# @return 0 on success, 1 on failure.
kc_ngr_read_all() {
    cat
}

# Splits the given text into tokens using the separator characters.
# @param $1 Input text
# @param $2 Separator character set
# @return 0 on success, 1 on failure.
kc_ngr_split_tokens() {
    local text="$1"
    local sep="$2"
    printf '%s' "$text" | tr "$sep" '\n' | sed '/^$/d'
}

# Writes one output line to standard output.
# @param $1 Output line
# @return 0 on success, 1 on failure.
kc_ngr_write_line() {
    local line="$1"
    printf '%s\n' "$line"
}

# Returns 0 when the given span is fully contained inside one closed span.
# @param $1 Candidate start index
# @param $2 Candidate end index
# @param $3 Name of closed start array
# @param $4 Name of closed end array
# @return 0 if closed, 1 otherwise.
kc_ngr_span_is_closed() {
    local start="$1"
    local end="$2"
    local starts_name="$3"
    local ends_name="$4"
    local -n starts_ref="$starts_name"
    local -n ends_ref="$ends_name"
    local i

    for ((i = 0; i < ${#starts_ref[@]}; i++)); do
        [ "$start" -ge "${starts_ref[$i]}" ] || continue
        [ "$end" -le "${ends_ref[$i]}" ] || continue
        return 0
    done

    return 1
}

# Appends one closed span.
# @param $1 Start index
# @param $2 End index
# @param $3 Name of closed start array
# @param $4 Name of closed end array
# @return 0 on success.
kc_ngr_close_span() {
    local start="$1"
    local end="$2"
    local starts_name="$3"
    local ends_name="$4"
    local -n starts_ref="$starts_name"
    local -n ends_ref="$ends_name"

    starts_ref+=("$start")
    ends_ref+=("$end")
    return 0
}

# Executes the optional command for one chunk.
# The chunk is passed on stdin.
# Any stdout produced by the command closes the span.
# Environment:
#   KC_NGR_START  Start token index
#   KC_NGR_END    End token index
#   KC_NGR_SIZE   Window size
# @param $1 Command
# @param $2 Chunk text
# @param $3 Start index
# @param $4 End index
# @param $5 Window size
# @return 0 on success.
kc_ngr_run_cmd() {
    local cmd="$1"
    local line="$2"
    local start="$3"
    local end="$4"
    local size="$5"

    [ -n "$cmd" ] || return 0

    KC_NGR_START="$start" \
    KC_NGR_END="$end" \
    KC_NGR_SIZE="$size" \
    bash -lc "$cmd" <<<"$line"
}

# Emits descending sliding-window n-grams for the given input text.
# Optionally executes one external command per chunk and closes spans when that
# command writes anything to stdout.
# @param $1 Maximum tokens
# @param $2 Minimum tokens
# @param $3 Separator character set
# @param $4 Input text
# @param $5 Optional command
# @return 0 on success, 1 on failure.
kc_ngr_execute() {
    local max_tokens="$1"
    local min_tokens="$2"
    local sep_chars="$3"
    local input_text="$4"
    local cmd="$5"
    local -a tokens=()
    local -a closed_starts=()
    local -a closed_ends=()
    local token_count
    local loop_max
    local window_sz
    local start
    local end
    local index
    local line
    local cmd_output

    : "${closed_starts[@]}" "${closed_ends[@]}"

    mapfile -t tokens < <(kc_ngr_split_tokens "$input_text" "$sep_chars")
    token_count="${#tokens[@]}"

    [ "$token_count" -eq 0 ] && return 0

    loop_max="$max_tokens"
    [ "$token_count" -lt "$loop_max" ] && loop_max="$token_count"

    for ((window_sz = loop_max; window_sz >= min_tokens; window_sz--)); do
        for ((start = 0; start <= token_count - window_sz; start++)); do
            end=$((start + window_sz - 1))

            kc_ngr_span_is_closed "$start" "$end" closed_starts closed_ends && continue

            line="${tokens[$start]}"
            for ((index = 1; index < window_sz; index++)); do
                line="$line ${tokens[$((start + index))]}"
            done

            kc_ngr_write_line "$line" || return 1

            [ -n "$cmd" ] || continue

            cmd_output="$(kc_ngr_run_cmd "$cmd" "$line" "$start" "$end" "$window_sz")"
            [ -n "$cmd_output" ] || continue

            kc_ngr_close_span "$start" "$end" closed_starts closed_ends || return 1
        done
    done
}

# Application entry point.
# @return 0 on success, 1 on failure.
main() {
    local max_tokens=10
    local min_tokens=1
    local sep_chars=$' \t\r\n'
    local cmd=''
    local input_text

    while [ "$#" -gt 0 ]; do
        case "$1" in
            -h|--help)
                kc_ngr_help
                return 0
                ;;
            -max)
                shift
                [ -n "$1" ] || kc_ngr_fail "Missing value for -max." || return 1
                kc_ngr_is_int "$1" || kc_ngr_fail "Invalid value for -max." || return 1
                max_tokens="$1"
                ;;
            -min)
                shift
                [ -n "$1" ] || kc_ngr_fail "Missing value for -min." || return 1
                kc_ngr_is_int "$1" || kc_ngr_fail "Invalid value for -min." || return 1
                min_tokens="$1"
                ;;
            -sep)
                shift
                [ -n "${1+x}" ] || kc_ngr_fail "Missing value for -sep." || return 1
                sep_chars="$1"
                ;;
            -cmd)
                shift
                [ -n "${1+x}" ] || kc_ngr_fail "Missing value for -cmd." || return 1
                cmd="$1"
                ;;
            *)
                kc_ngr_fail "Unknown argument." || return 1
                ;;
        esac
        shift
    done

    [ "$min_tokens" -ge 1 ] || kc_ngr_fail "-min must be >= 1." || return 1
    [ "$max_tokens" -ge "$min_tokens" ] || kc_ngr_fail "-max cannot be less than -min." || return 1

    input_text="$(kc_ngr_read_all)" || kc_ngr_fail "Unable to read stdin content." || return 1
    [ -n "$input_text" ] || return 0

    kc_ngr_execute "$max_tokens" "$min_tokens" "$sep_chars" "$input_text" "$cmd" || \
    kc_ngr_fail "Failed to process n-grams."
}

main "$@"
