#!/bin/bash
# kc-tfr - Token Frequency Ranker
# Summary: Reorders input lines by candidate frequency across ranking maps.
# Author: KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

# Prints application usage help.
# @return 0 on success.
kc_tfr_help() {
    echo "Usage: kc-tfr [options]"
    echo
    echo "Options:"
    echo " -m, --map FILE Add ranking map. Repeatable."
    echo " -h, --help     Show help"
    echo
    echo "Input:"
    echo " Reads candidate lines from standard input."
    echo " Uses the first tab-separated field as the candidate key."
    echo " Preserves the full original line in the output."
    echo
    echo "Examples:"
    echo " echo \"docker\" | kc-tfr -m ~/.bash_history"
    printf '%s\n' " printf 'docker\\t0.91\\ndocument\\t0.87\\n' | kc-tfr -m ~/.bash_history"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_tfr_fail() {
    echo "Error: $1" >&2
    kc_tfr_help >&2
    return 1
}

# Removes temporary files created during execution.
# @return 0 on success.
kc_tfr_cleanup() {
    [ -n "$KC_TFR_INPUT_FILE" ] && [ -f "$KC_TFR_INPUT_FILE" ] && rm -f "$KC_TFR_INPUT_FILE"
    [ -n "$KC_TFR_COUNT_FILE" ] && [ -f "$KC_TFR_COUNT_FILE" ] && rm -f "$KC_TFR_COUNT_FILE"
    [ -n "$KC_TFR_SORT_FILE" ] && [ -f "$KC_TFR_SORT_FILE" ] && rm -f "$KC_TFR_SORT_FILE"
}

# Adds one readable ranking map file.
# @param $1 Map file path
# @return 0 on success, 1 on failure.
kc_tfr_add_map() {
    local file="$1"

    [ -n "$file" ] || return 1
    [ -f "$file" ] || return 1
    [ -r "$file" ] || return 1

    KC_TFR_MAPS+=("$file")
    return 0
}

# Reads input lines and stores indexed candidate records.
# @return 0 on success.
kc_tfr_read_input() {
    local line
    local index=0
    local key

    : > "$KC_TFR_INPUT_FILE"

    while IFS= read -r line || [ -n "$line" ]; do
        index=$((index + 1))
        key="${line%%$'\t'*}"
        printf '%s\t%s\t%s\n' "$index" "$key" "$line" >> "$KC_TFR_INPUT_FILE"
    done

    return 0
}

# Counts map matches for each unique candidate key.
# @return 0 on success.
kc_tfr_count() {
    awk -F '\t' '
        NR == FNR {
            key = $2
            if (!(key in seen)) {
                seen[key] = 1
                keys[++key_count] = key
                counts[key] = 0
            }
            next
        }
        {
            for (i = 1; i <= key_count; i++) {
                key = keys[i]
                if (key != "" && index($0, key) > 0) {
                    counts[key]++
                }
            }
        }
        END {
            for (i = 1; i <= key_count; i++) {
                key = keys[i]
                printf "%s\t%d\n", key, counts[key]
            }
        }
    ' "$KC_TFR_INPUT_FILE" "${KC_TFR_MAPS[@]}" > "$KC_TFR_COUNT_FILE"
}

# Sorts candidates by descending frequency and original position.
# @return 0 on success.
kc_tfr_sort() {
    awk -F '\t' '
        NR == FNR {
            counts[$1] = $2
            next
        }
        {
            line = $0
            sub(/^[^\t]*\t[^\t]*\t/, "", line)
            count = (($2 in counts) ? counts[$2] : 0)
            printf "%012d\t%012d\t%s\n", count, $1, line
        }
    ' "$KC_TFR_COUNT_FILE" "$KC_TFR_INPUT_FILE" \
    | sort -t $'\t' -k1,1nr -k2,2n > "$KC_TFR_SORT_FILE"

    awk -F '\t' '
        {
            line = $0
            sub(/^[^\t]*\t[^\t]*\t/, "", line)
            print line
        }
    ' "$KC_TFR_SORT_FILE"
}

# Runs CLI parsing and ranking execution.
# @param $@ Application arguments
# @return 0 on success, 1 on failure.
main() {
    local arg

    KC_TFR_MAPS=()
    KC_TFR_INPUT_FILE="$(mktemp)" || return 1
    KC_TFR_COUNT_FILE="$(mktemp)" || {
        kc_tfr_cleanup
        return 1
    }
    KC_TFR_SORT_FILE="$(mktemp)" || {
        kc_tfr_cleanup
        return 1
    }

    trap kc_tfr_cleanup EXIT INT TERM

    while [ "$#" -gt 0 ]; do
        arg="$1"

        case "$arg" in
            -h|--help)
                kc_tfr_help
                return 0
                ;;
            -m|--map)
                shift
                [ -n "$1" ] || kc_tfr_fail "Missing value for $arg." || return 1
                kc_tfr_add_map "$1" || kc_tfr_fail "Invalid map." || return 1
                ;;
            -*)
                kc_tfr_fail "Unknown argument." || return 1
                ;;
            *)
                kc_tfr_fail "Unknown argument." || return 1
                ;;
        esac

        shift
    done

    [ "${#KC_TFR_MAPS[@]}" -gt 0 ] || kc_tfr_fail "Missing map." || return 1

    kc_tfr_read_input || return 1
    [ -s "$KC_TFR_INPUT_FILE" ] || return 0
    kc_tfr_count || return 1
    kc_tfr_sort || return 1
}

main "$@"
