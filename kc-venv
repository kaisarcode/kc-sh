#!/bin/bash

# kc-venv - Virtual Environment.
# Summary: Activates a directory as a virtual environment root.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

# Prints application usage help.
# @return 0 on success.
kc_venv_help() {
    printf 'Usage: kc-venv [options] [init] <directory>\n'
    printf '\n'
    printf 'Options:\n'
    printf '  <directory>    Directory to activate as the virtual environment root\n'
    printf '  init           Initialize a new environment in an empty directory\n'
    printf '  -h, --help     Show help\n'
    printf '\n'
    printf 'Examples:\n'
    printf '  kc-venv ./my-env\n'
    printf '  kc-venv init ./new-env\n'
}

# Prints one error message to standard error and exits.
# @param $1 Error message.
# @return 1 on failure.
kc_venv_fail() {
    printf 'kc-venv: error: %s\n' "$1" >&2
    return 1
}

# Detects the host CPU architecture.
# @return Prints the architecture string on success.
kc_venv_detect_arch() {
    case "$(uname -m)" in
        x86_64)  printf 'x86_64\n' ;;
        aarch64) printf 'aarch64\n' ;;
        armv7l)  printf 'armv7l\n' ;;
        *)       printf '%s\n' "$(uname -m)" ;;
    esac
}

# Detects the host platform.
# @return Prints the platform string on success.
kc_venv_detect_platform() {
    case "$(uname -s)" in
        Linux)  printf 'linux\n' ;;
        Darwin) printf 'darwin\n' ;;
        *)      printf '%s\n' "$(uname -s | tr '[:upper:]' '[:lower:]')" ;;
    esac
}

# Checks if a directory is empty.
# @param $1 Directory path.
# @return 0 if empty, 1 otherwise.
kc_venv_is_empty() {
    [ -z "$(ls -A "$1" 2>/dev/null)" ]
}

# Ensures one directory exists.
# @param $1 Directory path.
# @return 0 on success or negative on failure.
kc_venv_dir_ensure() {
    [ -d "$1" ] && return 0
    mkdir -p "$1"
}

# Prepares the virtual environment directory structure.
# @param $1 Root path.
# @param $2 Architecture.
# @param $3 Platform.
# @return 0 on success or 1 on failure.
kc_venv_root_prepare() {
    local root="$1"
    local arch="$2"
    local platform="$3"

    kc_venv_dir_ensure "$root" || return 1
    kc_venv_dir_ensure "$root/bin" || return 1
    kc_venv_dir_ensure "$root/lib" || return 1
    kc_venv_dir_ensure "$root/etc" || return 1
    kc_venv_dir_ensure "$root/etc/xdg" || return 1
    kc_venv_dir_ensure "$root/tmp" || return 1
    kc_venv_dir_ensure "$root/var" || return 1
    kc_venv_dir_ensure "$root/run" || return 1
    kc_venv_dir_ensure "$root/share" || return 1
    kc_venv_dir_ensure "$root/opt/arch/$arch/$platform/bin" || return 1
    kc_venv_dir_ensure "$root/opt/arch/$arch/$platform/lib" || return 1

    touch "$root/.sudo_as_admin_successful"
}

# Activates the virtual environment in the current shell process.
# @param $1 Root path.
# @param $2 Architecture.
# @param $3 Platform.
# @return Does not return on success, 1 on failure.
kc_venv_activate() {
    local root="$1"
    local arch="$2"
    local platform="$3"
    local branch="$root/opt/arch/$arch/$platform"
    local shell="${SHELL:-/bin/sh}"

    HOME="$root"
    TMPDIR="$root/tmp"
    PWD="$root"
    KC_VENV=1
    KC_VENV_ROOT="$root"
    KC_VENV_ARCH="$arch"
    KC_VENV_PLATFORM="$platform"
    KC_VENV_BRANCH="$branch"
    SHELL="$shell"
    PATH="$root/bin:$branch/bin:$PATH"
    LIBRARY_PATH="$root/lib:$branch/lib"
    LD_LIBRARY_PATH="$root/lib:$branch/lib"
    C_INCLUDE_PATH="$root/lib/include:$branch/lib/include"
    CPLUS_INCLUDE_PATH="$root/lib/include:$branch/lib/include"
    PKG_CONFIG_PATH="$root/lib/pkgconfig:$branch/lib/pkgconfig"
    XDG_CONFIG_HOME="$root/.config"
    XDG_CACHE_HOME="$root/.cache"
    XDG_DATA_HOME="$root/.local/share"
    XDG_STATE_HOME="$root/.local/state"
    XDG_RUNTIME_DIR="$root/run"
    XDG_CONFIG_DIRS="$root/etc/xdg"
    XDG_DATA_DIRS="$root/share"

    export HOME TMPDIR PWD KC_VENV KC_VENV_ROOT KC_VENV_ARCH KC_VENV_PLATFORM KC_VENV_BRANCH
    export SHELL PATH LIBRARY_PATH LD_LIBRARY_PATH C_INCLUDE_PATH CPLUS_INCLUDE_PATH
    export PKG_CONFIG_PATH XDG_CONFIG_HOME XDG_CACHE_HOME XDG_DATA_HOME
    export XDG_STATE_HOME XDG_RUNTIME_DIR XDG_CONFIG_DIRS XDG_DATA_DIRS

    cd "$root" || return 1
    exec "$shell" -i
}

# Runs the kc-venv runtime entry point.
# @param $@ Script arguments.
# @return 0 on success, 1 on failure.
main() {
    local root_path=''
    local root
    local arch
    local platform
    local init=0

    if [ "$1" = 'init' ]; then
        init=1
        shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                kc_venv_help
                return 0
                ;;
            -*)
                kc_venv_fail "Unknown option: $1" || return 1
                ;;
            *)
                if [ -z "$root_path" ]; then
                    root_path="$1"
                else
                    kc_venv_fail "Unexpected argument: $1" || return 1
                fi
                ;;
        esac
        shift
    done

    [ -n "$root_path" ] || kc_venv_fail "No directory given." || return 1

    if [ "$init" -eq 1 ]; then
        kc_venv_dir_ensure "$root_path" || kc_venv_fail "Could not create: $root_path" || return 1
        kc_venv_is_empty "$root_path" || kc_venv_fail "Directory is not empty: $root_path" || return 1
    else
        [ -d "$root_path" ] || kc_venv_fail "Directory does not exist: $root_path (use --init to create)" || return 1
    fi

    root="$(realpath "$root_path")" || kc_venv_fail "Cannot resolve path: $root_path" || return 1
    arch="$(kc_venv_detect_arch)"
    platform="$(kc_venv_detect_platform)"

    if [ "$init" -eq 1 ]; then
        kc_venv_root_prepare "$root" "$arch" "$platform" || kc_venv_fail "Failed to prepare environment." || return 1
    fi

    kc_venv_activate "$root" "$arch" "$platform" || kc_venv_fail "Failed to activate environment." || return 1
}

main "$@"
